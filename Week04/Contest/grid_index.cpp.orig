        #else

        char ch = grid[index / nArray][index % nArray];
        switch (ch) {
            case '>':
                index++;
            break;

            case '<':
                index--;
            break;

            case '^':
                index -= nArray;
            break;

            case 'v':
                index += nArray;
            break;
        }

        #endif
    }

    return index;
}

