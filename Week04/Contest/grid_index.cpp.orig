#ifdef FUNCTION_PTR_LOOKUP

void up(size_t* index, size_t width) {
    (*index) -= width;
}

void down(size_t* index, size_t width) {
    (*index) += width;
}

void right(size_t* index, size_t width) {
    (*index) += 1;
}

void left(size_t* index, size_t width) {
    (*index) -= 1;
}

typedef void (move_t(size_t*, size_t));

